#include <bits/stdc++.h> 

int minimizeIt(vector<int> A, int K)
{  
    int n=A.size();
  if(n==1) return 0;
    sort(A.begin(),A.end());
    int diff=A[n-1]-A[0];
    int mini,maxi;
    for(int i=0;i<n;i++){
        if(A[i]-K<0) 
            continue;
        
        maxi=max(A[i-1]+K,A[n-1]-K);
        mini=min(A[0]+K,A[i]-K);
        diff=min(diff,maxi-mini);
    }
    return diff;
    
}