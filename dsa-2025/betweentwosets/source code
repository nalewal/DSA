#include<iostream>
using namespace std;
int main()
{
	int m,n;
	cin>>n>>m;
	int ar1[n];
	int ar2[m];
	for(int i=0;i<n;i++){
	cin>>ar1[i];
}
	for(int i=0;i<m;i++){
	 cin>>ar2[i];
}
int count=0;
bool flag;
int fct=ar1[n-1];
while(fct<=ar2[0]){
	flag=0;
	for(int j=0;j<n;j++){
		if(fct%ar1[j]!=0){
			flag=1;
			break;
		}
		if(flag==0){
			for(int i=0;i<m;i++){
				if(ar2[i]%fct!=0){
					flag=1;
					break;
				}
				
			}
		}
	}
	if(flag==0){
		count++;
	}
	fct++;
}
	
	cout<<count<<endl;
	return 0;
}
