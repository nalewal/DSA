#include<iostream>
using namespace std;
int main()
{
	int n;
	cin>>n;
	int score[n];
	for(int i=0;i<n;i++){
		cin>>score[i];
	}
	int mx=score[0];
	int min=score[0];
	int mxcount=0;
	int mncount=0;
	for(int i=0;i<n;i++){
		if(score[i]>mx){
			mx=score[i];
			mxcount++;
		}
		for(int i=0;i<n;i++){
			if(score[i]<min){
				min=score[i];
				mncount++;
			}
		}
	}
	cout<<mxcount<<" "<<mncount<<endl;
	return 0;
}