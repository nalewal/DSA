#include<iostream>
using namespace std;
int main()
{
    int x1,v1,x2,v2;
    cin>>x1>>v1>>x2>>v2;
    if(x1>x2&&v1>v2||x2>x1&&v2>v1){
        cout<<"NO"<<endl;
        return 0;
    }
    if(x1==x2&&v1>v2||x1==x2&&v2<v1){
        cout<<"NO"<<endl;
    }
    if(x1>x2&&v1==v2||x2<x1&&v1==v2){
        cout<<"NO"<<endl;
    }
    bool tell=false;
    while(1){
       
        
        if((x1+v1)==(x2+v2)){
            tell=true;
            break;
        }
    
        x1=x1+v1;
        x2=x2+v2;
        if(x1>x2){
        	tell=false;
        	break;
		}
        
    }
    if(tell){
        cout<<"YES"<<endl;
    }
    else{
        cout<<"NO"<<endl;
    }
    return 0;
}