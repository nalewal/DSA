#include<iostream>
using namespace std;

int main()
{
	int n;
	int a[n];
	cin>>n;
	for(int i=0;i<n;i++)
		cin>>a[i];
	for(int i=0;i<n;i++){
		if(a[i]>=38){
			int rem=a[i]%5;
			int least_mult=a[i]-rem;
			int upper_mult=least_mult+5;
			int diff=upper_mult-a[i];
			if(diff<3){
				a[i]=upper_mult;
			}
		}
	}
	for(int i=0;i<n;i++){
		cout<<a[i]<<endl;
	}
	return 0;
}
